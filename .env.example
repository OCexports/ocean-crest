# SMTP configuration for the contact / inquiry form.
# Copy this file to .env.local and fill in your real mail server credentials.
# .env.local is git-ignored, so secrets never get committed.

# Your mail server hostname (from your hosting / email provider).
SMTP_HOST=mail.ocexports.com

# 587 = STARTTLS (most common), 465 = implicit TLS/SSL, 25 = unencrypted.
SMTP_PORT=587

# Optional: force TLS mode. Leave blank to auto-pick (true when port is 465).
SMTP_SECURE=

# The mailbox you authenticate with.
SMTP_USER=priyam.sheth@ocexports.com
SMTP_PASS=your-mailbox-password-or-app-password

# Optional. "From" address on outgoing mail. Many hosts require this to match
# SMTP_USER or a verified domain. Defaults to SMTP_USER if left blank.
SMTP_FROM=priyam.sheth@ocexports.com

# Where inquiry emails are delivered. Defaults to priyam.sheth@ocexports.com.
SMTP_TO=priyam.sheth@ocexports.com
